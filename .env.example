# GitHub Models is the default provider. Create a GitHub fine-grained personal
# access token with the "Models: Read" permission and keep the value private.
LLM_PROVIDER=github-models
GITHUB_MODELS_TOKEN=replace_me
GITHUB_MODELS_MODEL=openai/gpt-4.1-mini

# Optional OpenAI fallback. Use this instead by setting LLM_PROVIDER=openai.
# OPENAI_API_KEY=replace_me
# OPENAI_MODEL=gpt-4.1-mini
PORT=3000
